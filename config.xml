<?xml version='1.0' encoding='utf-8'?>
<widget id="com.salims.videoapp" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>vid-animationApp</name>
    <description>
        An app container to show image and icon. Video-to-animation logic can be added later.
    </description>
    <author email="you@example.com" href="https://example.com">
        Salim
    </author>
    <content src="index.html" />
    <access origin="*" />
    <preference name="Fullscreen" value="true" />
    <preference name="Orientation" value="portrait" />

    <!-- Android icon -->
    <platform name="android">
        <icon src="res/icon.png" />
    </platform>

    <!-- You can add more platform-specific icons or splash screens here -->
</widget>
